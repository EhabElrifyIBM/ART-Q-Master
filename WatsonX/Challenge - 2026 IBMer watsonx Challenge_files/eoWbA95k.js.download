(function () {window.BH = window.BH || {};BH.getProjectConfig = function (url=window.location.href) {var pcscript = document.getElementById("beeheard-projectconfig-script");var includedscript = document.querySelector('script[src^="https://beeheard.beeheard.dal.app.cirrus.ibm.com"]');var nonce = includedscript ? includedscript.nonce : "";if (nonce) {var script = document.createElement("script");script.id = "beeheard-projectconfig-script";script.type = "text/javascript";script.src = "https://beeheard.beeheard.dal.app.cirrus.ibm.com/survey/projectconfig/eoWbA95k.js?url=" + encodeURIComponent(url);script.setAttribute("nonce", nonce);if (pcscript) {pcscript.remove();}document.body.appendChild(script);} else {var xhr = new XMLHttpRequest();xhr.withCredentials = true;xhr.onreadystatechange = function () {if (xhr.readyState == 4 && xhr.status == 200) {var script = document.createElement("script");script.id = "beeheard-projectconfig-script";script.type = "text/javascript";script.text = xhr.responseText;if (pcscript) {pcscript.remove();}document.body.appendChild(script);}};xhr.open('POST', "https://beeheard.beeheard.dal.app.cirrus.ibm.com/survey/projectconfig/eoWbA95k.js");xhr.setRequestHeader('Content-type', 'application/x-www-form-urlencoded');xhr.send('url='+encodeURIComponent(url));}};if (window.BHConfig && window.BHConfig.isBot) {return;}BH.getProjectConfig();})();