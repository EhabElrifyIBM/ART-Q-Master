      <script>
       ${n?`
       async function feedbackHandler(event) {
          if(event.interactionType !== "submitted") return;
          try {
            const feedbackData = {
              submitted_at: new Date().toISOString(),
              thread_id: event.message?.threadId || '',
              message_id: event.message?.messageId || '',
              is_positive: event.isPositive || false,
              feedback_categories: event.categories || [],
              feedback_text: event.text || ''
            };
            
            await window.submitWxoChatFeedback(feedbackData);
          } catch (err) {
            console.error('Error submitting feedback:', err);
          }
        }

        async function preReceiveHandler(event) {
            const lastItem = event?.message?.content?.[event.message.content.length - 1];
            if (lastItem) {
                try {
                    const payload = {
                        thread_id: event?.message?.threadId || '',
                        message_id: event?.message?.messageId || '',
                        message: lastItem?.text || ''
                    };
                    
                    const feedbackConfig = await window.getWxoChatFeedbackConfig(payload);
                    if (feedbackConfig) {
                        lastItem.message_options = { feedback: feedbackConfig };
                    }
                } catch (err) {
                    console.error('Error fetching feedback config in preReceiveHandler:', err);
                }
            }
        }
        `:``}

        window.wxOConfiguration = {
          clientVersion: "${e.clientVersion}",
          orchestrationID: "${e.orchestrationId}",
          hostUrl: "${e.hostUrl}",
          hostURL: "${e.hostUrl}",
          rootElementID: "${e.rootElementId}",
          showLauncher: ${e.showLauncher}, // set to false to render the chat window directly
          token: ${e.token?`"${e.token}"`:`undefined`},
          chatOptions: ${e.chatOptions?`{ 
               agentId: "${e.chatOptions.agentId}",
               agentEnvironmentId: "${e.chatOptions.agentEnvironmentId}",
               onLoad: ${e.token||n?`function (instance) {
                         ${e.token?`
                         instance.on('authTokenNeeded',
                           async function(event) {
                             await window.getIdToken(event);
                           }
                         );
                         instance.on('identityTokenExpired',
                           async function(event) {
                             await window.getIdToken(event);
                           }
                         );
                         `:``}
                         ${n?`
                         instance.on('pre:receive', preReceiveHandler);
                         instance.on('feedback', feedbackHandler);
                         `:``}
                     }`:`undefined`}
               }`:`undefined`},
          layout: ${e.layout?`{
              form: "${e.layout.form}",
              showOrchestrateHeader: ${e.layout.showOrchestrateHeader},
              ${e.layout.width?`width: "${e.layout.width}px",`:``}
              ${e.layout.height?`height: "${e.layout.height}px",`:``}
            }`:`undefined`},
        };

        // following two lines are newly inserted and added if condition to support wxo gen2
        if(!window.wxOConfiguration.chatOptions?.agentId) {
          document.body.prepend(document.getElementById(window.wxOConfiguration.rootElementID));
          document.head.appendChild(document.createElement("style")).appendChild(document.createTextNode("html[data-mfe] body > :not(#" + window.wxOConfiguration.rootElementID +") { display: none; }"));
        }

        const scriptUrl = "${e.hostUrl}${e.chatOptions?`/wxochat/wxoLoader.js?embed=true`:`/webclient/wxoLoader.js`}";

        setTimeout(function () {
          const script = document.createElement('script');
          script.src = scriptUrl;
          script.addEventListener('load', function () {
            try {
              wxoLoader.init();
            } catch (e) {
              console.error('Error while initializing WX Loader', e);
            }
          });
          document.head.appendChild(script);
          }, 0
        );
      <\/script>
      `},setChatbotScript(e){return e.clientVersion=`8.12.2`,`
      <script>
        var typeahead_cache = "";
        var typeahead_menu = [];
        var debug = false; // Set to true to see some debugging messages in the console

        window.watsonAssistantChatOptions = {
          integrationID: "${e.integrationId}",
          region: "${e.region}",
          serviceInstanceID: "${e.serviceInstanceId}",
          clientVersion: "${e.clientVersion}",
          subscriptionID: "${e.subscriptionId||``}",
          orchestratePrivateHostURL: "${e.orchestratePrivateHostUrl||``}",
          cloudPrivateHostURL: "${e.cloudPrivateHostUrl||``}",
          showRestartButton: true,
          onLoad: async function (instance) {
            // Print events when debugging
            if (debug) instance.on({type: '*', handler: (event) => console.log(event.type)});
            // Initialize the suggestion box
            instance.on({type: 'chat:ready', handler: () => chat_ready(instance)});
            // Initializes the typeahead list when a conversation is started
            instance.on({type: 'receive', handler: init_typeahead_list});

            await instance.render();
          },
        };
        setTimeout(function () {
          const t = document.createElement("script");
          t.src =
            "https://web-chat.global.assistant.watson.appdomain.cloud/versions/${e.clientVersion}/WatsonAssistantChatEntry.js";
          document.head.appendChild(t);
        });
        function init_typeahead_list(event) {
          if ( event.data === undefined) { if (debug) console.log("No data"); return; }
          try {
            if ( event.data.context.skills["actions skill"].skill_variables === undefined) { if (debug) console.log("No context"); return; }

            // load variables from watsonx assistant
            if (event.data.context.skills["actions skill"].skill_variables["type_ahead_menu"] && typeahead_cache === ""){
              if (debug) console.log(event.data.context.skills["actions skill"].skill_variables["type_ahead_menu"]);
              typeahead_cache = event.data.context.skills["actions skill"].skill_variables["type_ahead_menu"];
              typeahead_menu = typeahead_cache.split(",");
            }
          } catch ( err) {
            return;
          }
        }

        function thekeyispressed(value, instance) {
          var input = value;

          try{
            if (debug) console.log(input);

            var suggestions = [];

            var suggestionBox = document.getElementById('suggestionBox');
            suggestionBox.innerHTML = '';

            // Display suggestions only when at least 3 letters are entered
            if (input.length >= 3) {
              suggestions = typeahead_menu.filter(function (item) {
                return item.toLowerCase().includes(input.toLowerCase());
              });
            }

            // Display (or hide) the suggestion box
            if(suggestions.length > 0) {
              suggestionBox.style.paddingTop = "32px";
              suggestionBox.style.paddingBottom = "32px";
            } else {
              suggestionBox.style.paddingTop = "0px";
              suggestionBox.style.paddingBottom = "0px";
            }
            // Add items to the suggestion box
            suggestions.forEach(function (item) {
              var div = document.createElement('div');
              div.tabIndex = 0;
              let regex = new RegExp(value, 'i');
              div.innerHTML = item.replace(regex,\`<div style="font-weight: bold; display:inline">\${value}</div>\`).trim();
              div.style.lineHeight = "22px";
              div.style.fontSize = "16px";
              div.style.paddingLeft = "16px";
              div.style.paddingRight = "16px";
              div.style.paddingTop = "5px";
              div.style.paddingBottom = "5px";
              div.style.display = "flex";
              div.style.whiteSpace = "pre";

              div.addEventListener('mouseenter', function() {
                this.style.backgroundColor = "rgb(141, 141, 141, 0.12)"; // "#8D8D8D";
              });
              div.addEventListener('mouseleave', function() {
                this.style.backgroundColor = "white"; // Revert to original background color
              });
              div.addEventListener('mousedown', function () {
                this.style.border = "2px solid blue";
                this.style.outline = "none";
                this.style.backgroundColor = "rgb(141, 141, 141, 0.50)"; // "#8D8D8D";
              });
              div.addEventListener('click', function () {
                instance.elements.getMessageInput().setValue(item);
                suggestionBox.style.paddingTop = "0px";
                suggestionBox.style.paddingBottom = "0px";
                suggestionBox.innerHTML = '';
                instance.elements.getMessageInput().getHTMLElement().focus();
              });
              div.addEventListener('keydown', function (e) {
                if (debug) console.log('Keydown:', e);
                if (e.which === 13) { // Ignore the enter key for selecting the item
                  e.preventDefault();
                  instance.elements.getMessageInput().setValue(item);
                  suggestionBox.style.paddingTop = "0px";
                  suggestionBox.style.paddingBottom = "0px";
                  suggestionBox.innerHTML = '';
                  instance.elements.getMessageInput().getHTMLElement().focus();
                }
              });
              div.addEventListener('focusin', function() {
                this.style.border = "2px solid blue";
                this.style.outline = "none";
                this.style.backgroundColor = "rgb(141, 141, 141, 0.50)"; // "#8D8D8D";
              });
              div.addEventListener('focusout', function() {
                this.style.border = "0px solid white";
                this.style.backgroundColor = "white"; // Revert to original background color
              });

              suggestionBox.appendChild(div);
            });
          } catch(e){
            console.log(e);
          }
        }

        function chat_ready(instance) {
          if (debug) console.log("Chat ready");

          const messageInput = instance.elements.getMessageInput();
          messageInput.addChangeListener(value => thekeyispressed(value, instance));

          let input_textarea = "WACInputContainer-TextArea";
          let suggestion_anchor = "beforeInputElement";

          var anchor = document.getElementById(suggestion_anchor);

          var suggestionBox = document.createElement('div');
          suggestionBox.id = "suggestionBox";
          suggestionBox.tabindex = 0;
          suggestionBox.style.border = "1px solid #FFF";
          suggestionBox.style.backgroundColor = "white";
          suggestionBox.style.zIndex = "1000";
          suggestionBox.style.paddingLeft = "0px";
          suggestionBox.style.maxHeight = "200px";
          suggestionBox.style.overflow = "auto";

          anchor.parentNode.insertBefore(suggestionBox, anchor);
        }
